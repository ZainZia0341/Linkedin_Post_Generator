# App runtime
APP_ENV=local
LOCAL_DB_DIR=schema/local_db
MAX_CHAT_MESSAGES=10
MAX_REVIEW_ATTEMPTS=3
TAVILY_SEARCH_RESULTS=5
TAVILY_POST_SEARCH_COUNT=6
TAVILY_RESULTS_PER_QUERY=3
API_PORT=7860
API_LIST_LIMIT=10
SCRAPE_MAX_WORKERS=2
SCRAPE_INTER_CREATOR_DELAY_MIN_SECONDS=0
SCRAPE_INTER_CREATOR_DELAY_MAX_SECONDS=240
EXTENSION_SCRAPE_TASK_TIMEOUT_SECONDS=300
EXTENSION_SCRAPE_TASK_LEASE_SECONDS=120
EXTENSION_API_TOKEN=

# DynamoDB Local
DYNAMODB_ENDPOINT_URL=http://localhost:8000
DYNAMODB_TABLE_PREFIX=linkedin_post_generator
DYNAMODB_AUTO_CREATE_TABLES=true
AWS_DEFAULT_REGION=us-east-2
AWS_ACCESS_KEY_ID=dummy
AWS_SECRET_ACCESS_KEY=dummy

# Primary LLM providers used by the app
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_LLM_MODEL=gemini-3.1-flash-lite
GROQ_API_KEY=<your-groq-api-key>
GOOGLE_API_KEY=<your-google-api-key>
GEMINI_IMAGE_MODEL=gemini-3.1-flash-lite-image
GENERATED_ASSET_DIR=./generated_assets
ANTHROPIC_API_KEY=<your-anthropic-api-key>
OPENAI_API_KEY=<your-openai-api-key>

# Search
TAVILY_API_KEY=<your-tavily-api-key>

# LinkedIn creator tracking. Async UI jobs use the Chrome extension; legacy
# direct Playwright endpoints remain available for an intentional rollback.
SCRAPING_ENABLED=true
LINKEDIN_DEFAULT_TRACK_URL=https://www.linkedin.com/in/theburningmonk/
LINKEDIN_AUTOMATION_MODE=logged_out
# LINKEDIN_AUTOMATION_MODE=burner
LINKEDIN_HEADLESS=true
LINKEDIN_CHECK_MAX_POSTS=5

# Burner credentials are not stored here.
# To use burner mode:
# 1. Set LINKEDIN_AUTOMATION_MODE=burner
# 2. Run: uv run python scripts/bootstrap_linkedin_session.py
# 3. Log in manually in the opened browser window with a burner account only.
# 4. Return to the app and click "Check for new posts".

# LangChain tracing
LANGCHAIN_API_KEY=<your-langchain-api-key>

# PDF services
PDF_SERVICES_CLIENT_ID=<your-pdf-services-client-id>
PDF_SERVICES_CLIENT_SECRET=<your-pdf-services-client-secret>

# Other available provider keys
MISTRAL_API_KEY=<your-mistral-api-key>
COHERE_API_KEY=<your-cohere-api-key>
OPENROUTER_API_KEY=<your-openrouter-api-key>
TOGETHER_AI_API_KEY=<your-together-ai-api-key>
HUGGINGFACE_TOKEN=<your-huggingface-token>
MULEROUTER_QWEN_API_KEY=<your-mulerouter-qwen-api-key>

# Vector database
PINECONE_API_KEY=<your-pinecone-api-key>

# Historical/commented keys and notes
# GROQ_API_KEY=<your-groq-api-key>
# ANTHROPIC_API_KEY=<your-anthropic-api-key>
# GOOGLE_API_KEY=<your-google-api-key>
# COHERE_API_KEY=<your-cohere-api-key>
# OPENROUTER_API_KEY=<your-openrouter-api-key>
# MISTRAL_API_KEY=<your-mistral-api-key>
# LANGCHAIN_API_KEY=<your-langchain-api-key>
# CLAUDE_API_KEY=<your-claude-api-key>
# PERPLEXITY_API_KEY=<your-perplexity-api-key>
# META_LLAMA_API_KEY=<your-meta-llama-api-key>
# XAI_GROK_API_KEY=<your-xai-grok-api-key>
# DEEPSEEP_API_KEY=<your-deepseep-api-key>
# KIMI_K2_MOONSHOOT_API_KEY=<your-kimi-k2-moonshoot-api-key>
